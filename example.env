# MindState example environment configuration
PGUSER=postgres
PGPASSWORD=secret
PGDATABASE=postgres
AGE_GRAPH=mindstate

#LLM_PROVIDER="openai"
LLM_PROVIDER="azure_openai"
AZURE_OPENAI_API_KEY=sk-yourkey
AZURE_OPENAI_ENDPOINT=your-endpoint-url
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

OPENAI_API_KEY=sk-yourkey
OPENAI_MODEL_NAME=gpt-4.1
#OPENAI_MODEL_NAME=gpt-5
#OPENAI_MODEL_NAME=gpt-5-mini
#OPENAI_TEMPERATURE=1 # Temperature must be between 0.1 and 1.0 for GPT5
OPENAI_TEMPERATURE=0

# MindState API mode
MS_API_HOST=127.0.0.1
MS_API_PORT=8000

# Embeddings for remember / recall / build_context
# Use "openai" (default), "azure_openai", or "local" for offline development.
MS_EMBEDDING_PROVIDER=openai
MS_EMBEDDING_MODEL=text-embedding-3-small
MS_EMBEDDING_DIMENSIONS=1536
MS_CHUNK_SIZE=500
MS_MAX_CHUNKS_PER_ITEM=64
MS_DEFAULT_RECALL_LIMIT=10
